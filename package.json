{
  "name": "devbox-cli",
  "version": "0.0.0",
  "description": "Local Kubernetes development environment orchestrator",
  "type": "module",
  "bin": {
    "devbox": "./bin/run.js"
  },
  "files": [
    "/bin",
    "/dist",
    "/templates",
    "/oclif.manifest.json"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && oclif manifest",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "start": "node ./bin/run.js"
  },
  "author": "Adrian Tomov",
  "license": "MIT",
  "dependencies": {
    "@oclif/core": "^4.9.0",
    "chalk": "^5.6.2",
    "execa": "^9.6.1",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0"
  },
  "oclif": {
    "bin": "devbox",
    "dirname": "devbox",
    "commands": "./dist/commands",
    "topicSeparator": " "
  }
}
